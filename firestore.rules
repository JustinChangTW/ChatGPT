rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function userRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'guest';
    }
    function isAdmin() { return userRole() == 'admin'; }

    // User profile + personal data (private to owner, readable by admin)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Shared docs
    match /publicData/{docId} {
      allow read: if true;
      // Question bank + system params are admin-only
      allow write: if (docId == 'cctShared' && isAdmin()) || (docId == 'cctSharedCommon' && isSignedIn());
    }

    // Public collaborative knowledge base (as requested: A & B)
    match /knowledgeBasePublic/{docId} {
      allow read, write: if true;
    }

    // Shared collaborative notes per question
    match /sharedQuestionNotes/{questionId} {
      allow read, write: if true;
    }

    // Compatibility collections
    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /generatedQuestions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Attempt records are private; admin can read all.
    match /practiceAttempts/{attemptId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if false;
    }

    match /wrongAnswers/{docId} {
      allow read, write: if isSignedIn() && (resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid || isAdmin());
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
