rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && request.auth.token.admin == true; }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Shared pool for demo/public mode.
    // Security hardening: require authentication (Google/anonymous) to prevent
    // unauthenticated internet users from overwriting public data.
    match /publicData/cctShared {
      allow read, write: if isSignedIn();
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /generatedQuestions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /practiceAttempts/{attemptId} {
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow update, delete: if false;
    }

    match /wrongAnswers/{docId} {
      allow read, write: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId) || isAdmin();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
